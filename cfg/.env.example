# Workflow provider: JSON (default) | MDB
WORKFLOW_PROVIDER=JSON
WORKFLOW_DIR=cfg/workflows

# LLM provider: LOCAL (default) | REMOTE
LLM_PROVIDER=LOCAL

# Local LLM configuration
LOCAL_MODEL_PATH=models/mistral-7b-instruct-v0.2.Q4_K_M.gguf
LOCAL_MODEL_N_CTX=4096
LOCAL_MODEL_N_THREADS=4
LOCAL_MODEL_TEMPERATURE=0.7

# Remote LLM (Gemini via langchain-google-genai / ChatGoogleGenerativeAI)
# With project: Vertex AI + ADC. Without project: GOOGLE_API_KEY or GEMINI_API_KEY (developer API).
GCP_PROJECT_ID=your-gcp-project
GCP_LOCATION=us-central1
# GOOGLE_CLOUD_PROJECT=...   # optional alias read if GCP_PROJECT_ID is unset
# GOOGLE_CLOUD_LOCATION=...  # optional alias read if GCP_LOCATION is unset
GEMINI_MODEL=gemini-2.5-flash
# GOOGLE_API_KEY=...
# GOOGLE_GENAI_USE_VERTEXAI=true

# MongoDB (required only when WORKFLOW_PROVIDER=MDB)
MDB_URI=mongodb://localhost:27017
MDB_DATABASE_NAME=workflowsDB
MDB_COLLECTION_NAME=workflows
