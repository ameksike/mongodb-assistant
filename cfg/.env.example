# Workflow provider: JSON (default) | MDB
WORKFLOW_PROVIDER=JSON
WORKFLOW_DIR=cfg/workflows

# LLM provider: LOCAL (default) | REMOTE | VERTEXAI
# LOCAL    — llama-cpp-python (in-process GGUF)
# REMOTE   — LangChain ChatGoogleGenerativeAI wrapper
# VERTEXAI — google-genai SDK direct (response_mime_type=application/json)
LLM_PROVIDER=LOCAL

# Prompt packaging for /api/process: text (default, prose + bullets) | json (single JSON with instruction, workflow, conversation, maxAnswers)
# LLM_PROMPT_FORMAT=json

# Local LLM configuration
LLM_LOCAL_MODEL_PATH=models/phi-2.Q4_K_M.gguf
LLM_LOCAL_MODEL_N_CTX=4096
LLM_LOCAL_MODEL_N_THREADS=4
LLM_LOCAL_MODEL_TEMPERATURE=0.7

# ---------------------------------------------------------------------------
# Remote LLM — TWO MUTUALLY EXCLUSIVE auth modes (pick ONE, not both):
#
#   Mode A) API key (simplest — no project, no gcloud, no ADC):
#       GOOGLE_API_KEY=AIza...
#       (do NOT set GOOGLE_GENAI_USE_VERTEXAI)
#
#   Mode B) Vertex AI (requires `gcloud auth application-default login`):
#       GOOGLE_GENAI_USE_VERTEXAI=true
#       GOOGLE_CLOUD_PROJECT=your-project-id
#       GOOGLE_CLOUD_LOCATION=us-central1
#       (do NOT set GOOGLE_API_KEY)
#
# Setting both GOOGLE_API_KEY and GOOGLE_GENAI_USE_VERTEXAI=true is a
# misconfiguration: Vertex AI takes precedence and the API key is ignored.
# ---------------------------------------------------------------------------
GOOGLE_MODEL_ID=gemini-2.5-flash
# GOOGLE_API_KEY=AIza...
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project
# GOOGLE_CLOUD_LOCATION=us-central1

# MongoDB (required only when WORKFLOW_PROVIDER=MDB)
MDB_URI=mongodb://localhost:27017
MDB_DATABASE_NAME=assistant
MDB_COLLECTION_NAME=workflows
